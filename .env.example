# ─────────────────────────────────────────────────────────────
# Atlas environment variables (template — copy, don't commit real values)
#
#  • Backend block  -> backend/.env locally, and Render env vars in production
#  • Frontend block -> frontend/.env locally, and Vercel/Netlify env var in prod
# ─────────────────────────────────────────────────────────────

# ===== BACKEND =====

# MongoDB — free cluster at https://www.mongodb.com/cloud/atlas
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=atlas

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000

# Public URLs — used to build the Gmail OAuth redirect
PUBLIC_BACKEND_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:3000

# AI — Google Gemini free tier. Get a key at https://aistudio.google.com/apikey
# Note: some accounts only have free-tier quota on newer models (e.g. gemini-3.5-flash).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Document storage — any S3-compatible store (Cloudflare R2 recommended).
#   R2:  S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com , S3_REGION=auto
#   AWS: leave S3_ENDPOINT_URL blank , set S3_REGION to your bucket's region
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Gmail integration (optional) — Google Cloud OAuth client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_NAME=life-admin

# ===== FRONTEND =====
# Point this at your deployed backend URL in production.
REACT_APP_BACKEND_URL=http://localhost:8000
